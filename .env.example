# Telegram bot token from @BotFather
BOT_TOKEN=

# SQLite database path (inside Docker volume)
DB_PATH=/app/data/finance_bot.db

# Comma-separated Telegram user IDs allowed to use the bot.
# This bot is single-user — set to your own Telegram ID.
ALLOWED_USERS=5904148250

# Default timezone for reminders and date display
TIMEZONE=Africa/Cairo

# Default language on first run (en | ar)
DEFAULT_LANGUAGE=en

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
